## SYNESI environment variables (example)
## Copy to `.env.local` for local development.

# Data backend switch
DATA_BACKEND=firebase

# Firebase (used when DATA_BACKEND=firebase)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# JSON string (single line) with service account credentials.
FIREBASE_SERVICE_ACCOUNT=
# Optional overrides
# FIREBASE_SESSION_COOKIE_NAME=__session
# FIREBASE_SESSION_MAX_AGE_MS=432000000
# FIREBASE_STORAGE_BUCKET=

# Supabase (rollback-only; leave empty in Firebase cutover)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Google sign-in: enable the Google provider and set Site URL + Redirect URLs in the Supabase Dashboard
# (Authentication → Providers; Authentication → URL configuration). No extra Next.js env secrets for the default OAuth flow.

# AI providers
MINIMAX_API_KEY=
MINIMAX_TEXT_MODEL=MiniMax-M2.7
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
BRAVE_SEARCH_API_KEY=
PERPLEXITY_API_KEY=

# External data APIs
ALPHA_VANTAGE_API_KEY=
EODHD_API_KEY=

# Financial refresh limits
FINANCIAL_REFRESH_DAILY_LIMIT_PER_USER=3
FINANCIAL_HYBRID_REFRESH_ENABLED=1
FINANCIAL_EXTENDED_ENRICHMENT_ENABLED=0
CRON_MAX_FINANCIAL_TICKERS_PER_RUN=5
CRON_FINANCIAL_BATCH_SIZE=5
CRON_FINANCIAL_BATCH_DELAY_MS=1200

# Web Push (browser alerts for new events). Generate keys: `node scripts/generate-vapid-keys.mjs`
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@synesi.app

# Sigma Chat storage buckets
SIGMA_UPLOAD_BUCKET=sigma-chat-uploads
SIGMA_EXPORT_BUCKET=sigma-chat-exports

# Vercel Cron: add CRON_SECRET in the Vercel dashboard (random string). Vercel sends Authorization: Bearer with that value.
CRON_MAX_TICKERS_PER_RUN=8
CRON_MAX_SOURCE_DOCS_PER_RUN=50
CRON_MATCHING_MIN_CONFIDENCE=high
CRON_SIGMA_MONITOR_MAX_USERS_PER_RUN=25

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# Google Analytics (GA4)
NEXT_PUBLIC_GA_ID=

# Google AdSense (publisher client id, e.g. ca-pub-xxxxxxxx — public; omit to disable loader)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Optional: Playwright `npm run test:e2e` — app-shell transition checks (skipped if unset)
# E2E_EMAIL=
# E2E_PASSWORD=
